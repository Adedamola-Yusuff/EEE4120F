    [2560,1440], %2K QHD
    [3840,2160], %4K UHD
    [5120,2880], %5K
    [7680,4320]  %8K UHD
]

delete(gcp('nocreate'))
parpool(2)

example = mandelbrot_serial(800, 600, 1000);
mandelbrot_plot(example, 'example.png')

